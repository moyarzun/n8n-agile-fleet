# Copiar este archivo a .env y completar los valores antes de ejecutar

# API Key de MiniMax (https://api.minimax.io) — proveedor primario
MINIMAX_API_KEY=your_minimax_api_key_here

# API Key de OpenRouter (https://openrouter.ai) — fallback automático si MiniMax agota cuota
# Modelos usados: qwen/qwen-2.5-coder-32b-instruct (dev) · deepseek/deepseek-r1 (revisor)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Jira Cloud
JIRA_URL=https://yourcompany.atlassian.net
JIRA_USER=your_email@company.com
JIRA_API_TOKEN=your_jira_api_token_here

# Ruta absoluta del proyecto de software que los agentes modificarán
WORKSPACE_DIR=/ruta/absoluta/a/tu/proyecto
